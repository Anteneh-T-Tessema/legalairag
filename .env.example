# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ACCOUNT_ID=

# ─── Bedrock ─────────────────────────────────────────────────────────────────
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=4096

# ─── Document Storage ────────────────────────────────────────────────────────
S3_BUCKET_RAW=indyleg-raw-documents
S3_BUCKET_PROCESSED=indyleg-processed-chunks

# ─── SQS Queues ──────────────────────────────────────────────────────────────
SQS_INGESTION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/indyleg-ingestion
SQS_EMBEDDING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/indyleg-embedding
SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/indyleg-dlq

# ─── Database (pgvector) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://indyleg:changeme@localhost:5432/indyleg
VECTOR_DIMENSION=1024

# ─── OpenSearch (optional) ───────────────────────────────────────────────────
OPENSEARCH_HOST=https://localhost:9200
OPENSEARCH_INDEX=indyleg-legal-docs

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_SECRET_KEY=change-this-to-a-strong-random-secret
CORS_ORIGINS=http://localhost:3000

# ─── Indiana Courts API ───────────────────────────────────────────────────────
# Mycase / Odyssey public portal base URL
INDIANA_COURTS_API_BASE=https://public.courts.in.gov/api
INDIANA_COURTS_API_KEY=

# ─── Public Legal Sources ────────────────────────────────────────────────────
# CourtListener (Free Law Project) — register free at https://www.courtlistener.com/sign-in/
COURTLISTENER_API_TOKEN=
COURTLISTENER_MAX_PAGES=5
# law.resource.org Federal Reporter (no auth required)
LAW_RESOURCE_INDIANA_FILTER=true
# Indiana General Assembly statutes (no auth required)
INDIANA_IGA_API_BASE=https://iga.in.gov/api/20231116/mobile-sdk

# ─── Evaluation ──────────────────────────────────────────────────────────────
EVAL_DATASET_PATH=tests/data/eval_queries.json
EVAL_K_VALUES=[1,5,10]

# ─── Fraud Detection ─────────────────────────────────────────────────────────
FRAUD_DETECTION_TOP_K=50
FRAUD_BURST_FILING_THRESHOLD=5

# ─── Authority Ranking ───────────────────────────────────────────────────────
# 0.0 = pure retrieval score, 1.0 = pure court-hierarchy authority score
AUTHORITY_ALPHA_DEFAULT=0.30

# ─── Performance ─────────────────────────────────────────────────────────────
EMBEDDING_BATCH_SIZE=128
INGESTION_WORKER_CONCURRENCY=4
RERANK_TOP_K=20
RETRIEVAL_TOP_K=5
